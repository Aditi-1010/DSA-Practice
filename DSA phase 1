// 1 - ARMSTRONG NUMBER
//EXAMPLE : INPUT: NUM = 371 , OUTPUT: TRUE, EXPLANATION : (3^3 + 7^3 + 1^3 = 371)
#include<iostream>
#include<math.h>
using namespace std;
void armstrongnumber(int num){
   int original = num;
   int ans = 0;
   while(num>0){
      int rem = num%10;
      ans = ans + pow(rem, 3);
      num = num/10;
      }
   if(ans==original) cout<<"Armstrong number";
      else
         cout<<"Not an Armstrong number";
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   armstrongnumber(num);
}

// 2 - PRIME NUMBER
//EXAMPLE : INPUT: NUM = 5, OUTPUT: TRUE;
#include<iostream>
using namespace std;
bool isprime(int num){
   if(num <= 1){
       return false;
   }
   for(int i=2; i<=num/2; i++){
      if(num%i == 0){
         return false;
      }
   }
   return true;
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   if(isprime(num)){
      cout<<"Prime Number"<<endl;
   }
   else{
      cout<<"Not Prime"<<endl;
   }
}

// 3 - SUM OF ALL PALINDROME NUMBERS IN THE ARRAY
#include<iostream>
using namespace std;
bool palindrome(int num){
    int original = num;
    int ans = 0;
    while(num > 0){
        int rem = num % 10;
        ans = ans * 10 + rem;
        num = num / 10;
    }
    return ans == original;
}
int main(){
    int arr[5] = {1, 121, 33, 45, 99};
    int n = 5;
    int sum = 0;
    for(int i = 0; i < n; i++){

        if(palindrome(arr[i])){
            sum++;
        }
    }
    cout << "Palindrome count = " << sum;
    return 0;
}

// 4 - HIGHEST POWER OF 2
// EXAMPLE : INPUT: NUM = 20, OUTPUT: HIGHEST POWER OF 2 = 16
#include<iostream>
using namespace std;
int powerofnumber(int n){
   int power = 1;
   while(power*2 <= n){
      power = power * 2;
   }
   return power;
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   cout<<"The power of 2 is: "<<powerofnumber(num)<<endl;
}

// 5 - SERIES WHERE EACH TERM IS THE FACTORIAL OF THE POSITION
// EXAMPLE : INPUT: NUM = 5, OUTPUT: 1 2 6 24 120
#include<iostream>
using namespace std;
int factorial(int n){
    int fact = 1;
    for(int i=1; i<=n; i++){
        fact = fact * i;
    }
   return fact;
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   for(int i=1; i<=num; i++){
      cout<<factorial(i)<<" ";
   }
}

// 6 - COUNT NUMBER OF VOWELS IN A STRING
//EXAMPLE : INPUT: STRING = "abcdefgh", OUTPUT: 2
#include<iostream>
using namespace std;
int countvowels(string s){
    int count = 0;
   for(int i=0; i<s.size(); i++){
      if(s[i] == 'a' || s[i] == 'e' || s[i] == 'i' || s[i] == 'o' || s[i] == 'u'){
         count++;
      }
   }
   return count;
}
int main(){
   string s;
   cout<<"Enter the string: ";
   cin>>s;
   cout<<"The number of vowels are: "<<countvowels(s)<<endl;
}

