vii)   * * * * * *   INVERTED PYRAMID STAR PATTERN
        * * * *
         * * * 
         * *
          *
#include <iostream>
using namespace std;
int main() {
    int n;
    cout << "Enter the number: ";
    cin >> n;
    for(int i=n; i>=1; --i) {
        for(int space = 0; space < n - i; ++space)
            cout << "  ";
        for(int j=1; j<= 2 * i - 1; ++j)
            cout << "* ";
        cout << endl;
    }
    return 0;
}

