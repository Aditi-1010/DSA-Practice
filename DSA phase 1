// 1 - ARMSTRONG NUMBER
#include<iostream>
#include<math.h>
using namespace std;
void armstrongnumber(int num){
   int original = num;
   int ans = 0;
   while(num>0){
      int rem = num%10;
      ans = ans + pow(rem, 3);
      num = num/10;
      }
   if(ans==original) cout<<"Armstrong number";
      else
         cout<<"Not an Armstrong number";
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   armstrongnumber(num);
}
// 2 - PRIME NUMBER
#include<iostream>
using namespace std;
bool isprime(int num){
   if(num <= 1){
       return false;
   }
   for(int i=2; i<=num/2; i++){
      if(num%i == 0){
         return false;
      }
   }
   return true;
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   if(isprime(num)){
      cout<<"Prime Number"<<endl;
   }
   else{
      cout<<"Not Prime"<<endl;
   }
}
// 3 - SUM OF ALL PALINDROME NUMBERS IN THE ARRAY
#include<iostream>
using namespace std;
bool palindrome(int num){
    int original = num;
    int ans = 0;
    while(num > 0){
        int rem = num % 10;
        ans = ans * 10 + rem;
        num = num / 10;
    }
    return ans == original;
}
int main(){
    int arr[5] = {1, 121, 33, 45, 99};
    int n = 5;
    int sum = 0;
    for(int i = 0; i < n; i++){

        if(palindrome(arr[i])){
            sum++;
        }
    }
    cout << "Palindrome count = " << sum;
    return 0;
}
