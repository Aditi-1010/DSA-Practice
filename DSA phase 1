//Problem Solving in DSA (baiscs + intermediate)
// 1 - ARMSTRONG NUMBER
#include<iostream>
#include<math.h>
using namespace std;
void armstrongnumber(int num){
   int original = num;
   int ans = 0;
   while(num>0){
      int rem = num%10;
      ans = ans + pow(rem, 3);
      num = num/10;
      }
   if(ans==original) cout<<"Armstrong number";
      else
         cout<<"Not an Armstrong number";
}
int main(){
   int num;
   cout<<"Enter the number: ";
   cin>>num;
   armstrongnumber(num);
}
