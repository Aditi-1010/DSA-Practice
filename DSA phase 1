// 10 - CALCULATE GCD OF TWO NUMBERS USING EUCLID'S ALGORITHM
// EXAMPLE : INPUT: NUM1 = 48, NUM2 = 18, OUTPUT: GCD = 6
// EXPLANATION : 48/18 REMAINDER = 12, NOW 18/12 REMAINDER = 6, NOW 12/6 REMAINDER = 0, LAST NON ZERO REMAINDER = 6, SO GCD = 6
#include<iostream>
using namespace std;
int main(){
   int n1, n2;
   cout<<"Enter n1 and n2: ";
   cin>>n1>>n2;
   int rem = n1%n2;
   while(rem!=0){
      n1=n2;
      n2=rem;
      rem=n1%n2;
   }
   cout<<"GCD is: "<<n2;
}

// 11 - BINARY SEARCH USING RECUSRION
#include<iostream>
using namespace std;
int binarySearch(int arr[], int s, int e, int key){
   if(s>e) return -1;
   int mid = s + (e-s)/2;
   if(arr[mid]==key) return mid;
   if(arr[mid]>key) return binarySearch(arr,s,mid-1,key);
   return binarySearch(arr,mid+1,e,key);
}
int main(){
   int arr[5] = {1,2,3,4,5};
   int n = 5;
   int key;
   cout<<"Enter the key: ";
   cin>>key;
   cout<<"The index is: "<<binarySearch(arr,0,n-1,key)<<endl;
}

// 12 - MAXIMUM BETWEEN THE NUMBER OF POSITIVE AND NEGATIVE NUMBERS
// EXAMPLE : INPUT: NUMS=[-1,-2,1,2,3], OUTPUT: 3 (NUMBER OF POSITIVE NUMBERS > NUMBER OF NEGATIVE NUMBERS)
#include<iostream>
using namespace std;
int negativeCount(int arr[], int n){
   int count = 0;
   for(int i=0; i<n; i++){
      if(arr[i]<0) count++;
   }
   return count;
}
int positiveCount(int arr[], int n){
   int count = 0;
   for(int i=0; i<n; i++){
      if(arr[i]>0) count++;
   }
   return count;
}
int main(){
   int arr[5] = {-1,-2,1,2,3};
   int n = 5;
   cout<<"The negative count is: "<<negativeCount(arr,n)<<endl;
   cout<<"The positive count is: "<<positiveCount(arr,n)<<endl;
   cout<<"The maximum count is: "<<max(negativeCount(arr,n), positiveCount(arr,n))<<endl;
}

// 13 - MERGE SORT
#include <iostream>
#include <vector>
using namespace std;
// Merges two subarrays of arr[].
// First subarray is arr[left..mid]
// Second subarray is arr[mid+1..right]
void merge(int arr[], int left, int mid, int right) {
    int n1 = mid - left + 1;
    int n2 = right - mid;
    // Create temporary arrays
    int L[n1], R[n2];
    // Copy data to temp arrays L[] and R[]
    for (int i = 0; i < n1; i++)
        L[i] = arr[left + i];
    for (int j = 0; j < n2; j++)
        R[j] = arr[mid + 1 + j];
    // Merge the temp arrays back into arr[left..right]
    int i = 0, j = 0, k = left;
    while (i < n1 && j < n2) {
        if (L[i] <= R[j]) {
            arr[k] = L[i];
            i++;
        } else {
            arr[k] = R[j];
            j++;
        }
        k++;
    }
    // Copy any remaining elements of L[]
    while (i < n1) {
        arr[k] = L[i];
        i++;
        k++;
    }
    // Copy any remaining elements of R[]
    while (j < n2) {
        arr[k] = R[j];
        j++;
        k++;
    }
}
void mergeSort(int arr[], int left, int right) {
    if (left >= right) return; 
    int mid = left + (right - left) / 2; 
    mergeSort(arr, left, mid);      
    mergeSort(arr, mid + 1, right); 
    merge(arr, left, mid, right);
}
int main() {
    int arr[] = {12, 11, 13, 5, 6, 7};
    int arr_size = sizeof(arr) / sizeof(arr[0]);
    mergeSort(arr, 0, arr_size - 1);
   cout << "Sorted array: ";
    for (int i = 0; i < arr_size; i++)
        cout<< arr[i] << " ";
    return 0;
}

